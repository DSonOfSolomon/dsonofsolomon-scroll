# Production database
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE"

# Public canonical URL used for metadata, sitemap, and notification links
NEXT_PUBLIC_SITE_URL="https://dsonofsolomon.com"

# Admin login
ADMIN_USERNAME="admin"
ADMIN_PASSWORD_HASH="$2b$12$replace-with-output-from-npm-run-hash-admin-password"
ADMIN_SESSION_SECRET="replace-with-a-long-random-secret"

# Persistent production uploads
BLOB_READ_WRITE_TOKEN="vercel-blob-read-write-token"
