// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Creator {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  bio          String?
  heroImage    String?
  heroImageAlt String?
  heroEyebrow  String?
  heroTitle    String?
  heroSubtitle String?
  currentWorkingOn String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  posts          Post[]
  categories     Category[]
  subscribers    Subscriber[]
  followers      Follower[]
  letterRequests LetterRequest[]
  pageViews      PageView[]
  readingEvents  ReadingEvent[]
}

model Category {
  id        String   @id @default(cuid())
  name      String
  slug      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  creatorId String
  creator   Creator @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  posts Post[]

  @@unique([creatorId, slug])
}

model Post {
  id          String   @id @default(cuid())
  title       String
  slug        String
  excerpt     String
  content     String
  status      String   @default("draft")
  universe    String   @default("public")
  coverImage  String?
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  chapterLabel String?

  creatorId String
  creator   Creator @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  pageViews     PageView[]
  readingEvents ReadingEvent[]

  @@unique([creatorId, slug])
}

model Subscriber {
  id        String   @id @default(cuid())
  email     String
  name      String?
  tier      String   @default("free")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  creatorId String
  creator   Creator @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  @@unique([creatorId, email])
}

model LetterRequest {
  id          String   @id @default(cuid())
  name        String
  email       String
  tier        String
  message     String
  status      String   @default("pending")
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  creatorId   String
  creator     Creator @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  @@index([creatorId, createdAt])
}

model Follower {
  id             String   @id @default(cuid())
  endpoint       String   @unique
  p256dh         String
  auth           String
  status         String   @default("active")
  userAgent      String?
  lastNotifiedAt DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  creatorId String
  creator   Creator @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  @@index([creatorId, createdAt])
}

model PageView {
  id        String   @id @default(cuid())
  path      String
  sessionId String
  visitorId String
  referrer  String?
  userAgent String?
  createdAt DateTime @default(now())

  creatorId String
  creator   Creator @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  postId String?
  post   Post? @relation(fields: [postId], references: [id], onDelete: SetNull)

  @@index([creatorId, createdAt])
  @@index([path, createdAt])
  @@index([postId, createdAt])
}

model ReadingEvent {
  id        String   @id @default(cuid())
  sessionId String
  visitorId String
  milestone Int
  createdAt DateTime @default(now())

  creatorId String
  creator   Creator @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  postId String
  post   Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId, sessionId, milestone])
  @@index([creatorId, createdAt])
  @@index([postId, createdAt])
}
